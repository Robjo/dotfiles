{
  "style": "~/.config/waybar/style.css",

  "layer": "top",
  "position": "top",
  "height": 30,

  "modules-left": [
    "hyprland/workspaces",
  ],

  "modules-center": ["memory", "cpu", "temperature"],

  "modules-right": [
    "idle_inhibitor",
    "battery",
    "hyprland/language",
    "keyboard-state",
    "backlight",
    "pulseaudio",
    "network",
    "clock",
    "tray",
  ],

  "include": "~/.config/waybar/modules.jsonc",
}
